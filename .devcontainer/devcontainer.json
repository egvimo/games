{
    "name": "Flutter",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "Dart-Code.dart-code",
                "Dart-Code.flutter"
            ]
        }
    },
    "forwardPorts": [
        9100
    ],
    "remoteUser": "vscode",
    "containerUser": "vscode",
    "postCreateCommand": "flutter doctor"
}
